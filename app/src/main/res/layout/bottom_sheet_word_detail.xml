<?xml version="1.0" encoding="utf-8"?>
<!-- FrameLayout root so the headword can live in an overlay layer above
     the toolbar and the scroll view. WordDetailBottomSheet drives its
     translationY + scale from scroll position so it shrinks down into
     the toolbar's empty left slot as the user scrolls. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/ptBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar: the close button only — the headword overlay below
             paints itself into the empty left slot once it's pinned. -->
        <LinearLayout
            android:id="@+id/wordDetailToolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/ptBg"
            android:paddingStart="16dp"
            android:paddingEnd="4dp">

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnBackDetail"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="?attr/ptText"
                android:contentDescription="Close" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/detailScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <!-- The Kotlin code sets paddingTop dynamically to the
                 measured height of the overlay headword + a small gap,
                 so the reading/badges/definitions row sits flush below
                 it regardless of how tall the headword wraps to.
                 paddingBottom matches the sentence view so the floating
                 Anki pill doesn't cover the last row when scrolled. -->
            <LinearLayout
                android:id="@+id/detailContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/pt_section_h_padding"
                android:paddingBottom="64dp" />

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Floating Anki pill button — matches the sentence-screen design
         (bottom|end pill, alpha 0.85, 6dp elevation). -->
    <LinearLayout
        android:id="@+id/btnWordAddToAnki"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_anki_pill"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:elevation="6dp"
        android:alpha="0.85"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_card_stack"
            app:tint="?attr/ptAccentOn"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anki"
            android:textColor="?attr/ptAccentOn"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="2dp" />

    </LinearLayout>

    <!-- Headword overlay. Lives ABOVE the toolbar in z-order so the
         in-place scale-down can render inside the toolbar slot. The
         label starts aligned to the top of the page (occupying the
         toolbar's left slot at full size) and shrinks in place as the
         user scrolls — no translation. -->
    <TextView
        android:id="@+id/tvDetailHeadword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="60dp"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="?attr/ptText"
        android:letterSpacing="-0.02" />

</FrameLayout>
