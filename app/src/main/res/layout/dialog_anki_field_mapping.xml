<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptBg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/ptBg"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/ptText"
        app:titleTextColor="?attr/ptText" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/fieldMappingContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingTop="4dp"
            android:paddingBottom="20dp" />

    </androidx.core.widget.NestedScrollView>

    <!-- Footer with the Save CTA. Same accent-rounded-rect styling the
         review sheets use for their primary action; same height /
         margins so it feels like the same component to the user. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/ptBg">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/ptDivider" />

        <FrameLayout
            android:id="@+id/btnSaveMapping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:minHeight="60dp"
            android:background="@drawable/bg_anki_save_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/anki_field_mapping_save"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/ptAccentOn"
                android:duplicateParentState="true" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
