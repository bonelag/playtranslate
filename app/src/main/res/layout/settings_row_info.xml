<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable info row: title + optional subtitle on left, no widget on the right.
     Used for read-only entries like the always-on ML Kit translation backend. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/pt_row_min_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/pt_row_h_padding"
    android:paddingVertical="9dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.PT.RowTitle" />

        <TextView
            android:id="@+id/tvRowSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            style="@style/Text.PT.RowSubtitle" />
    </LinearLayout>

</LinearLayout>
