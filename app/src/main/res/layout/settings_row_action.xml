<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable action row: title + optional subtitle on left, pill button on right. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/pt_row_min_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/pt_row_h_padding"
    android:paddingVertical="@dimen/pt_row_v_padding">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="16dp">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.PT.RowTitle" />

        <TextView
            android:id="@+id/tvRowSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            style="@style/Text.PT.RowSubtitle" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRowAction"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:textSize="13sp"
        android:textAllCaps="false"
        android:paddingHorizontal="16dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
