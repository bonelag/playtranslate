<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_popup_card"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvPopupStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/ptText"
        android:textSize="16sp"
        android:gravity="center" />

    <ProgressBar
        android:id="@+id/progressBarPopup"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:max="100"
        android:progress="0" />

    <Button
        android:id="@+id/btnPopupCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@android:string/cancel"
        android:textColor="?attr/ptTextMuted"
        android:backgroundTint="?attr/ptDivider"
        android:minHeight="40dp" />

</LinearLayout>
