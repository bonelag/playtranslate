<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/ptSurface"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="?attr/ptText"
        app:navigationContentDescription="@string/deepl_settings_close_cd"
        app:title="@string/deepl_settings_title"
        app:titleTextColor="?attr/ptText" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="@dimen/pt_row_v_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DeepL API Key"
                            style="@style/Text.PT.RowTitle" />

                        <EditText
                            android:id="@+id/etDeeplKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/hint_deepl_key"
                            android:textColorHint="?attr/ptTextHint"
                            android:textColor="?attr/ptText"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:singleLine="true"
                            android:inputType="textVisiblePassword"
                            android:background="?attr/ptSurface"
                            android:padding="10dp"
                            android:importantForAutofill="no" />
                    </LinearLayout>

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_link"
                        android:id="@+id/rowDeeplLink" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_word_tatoeba_attribution"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/deepl_settings_about"
                        android:textColor="?attr/ptTextHint"
                        android:textSize="11sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/deepl_settings_save"
        android:textAllCaps="false" />

</LinearLayout>
