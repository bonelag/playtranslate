<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable link row: title + optional subtitle on left, external-link icon on right. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/pt_row_min_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/pt_row_h_padding"
    android:paddingVertical="@dimen/pt_row_v_padding"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="16dp">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.PT.RowTitle" />

        <TextView
            android:id="@+id/tvRowSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            style="@style/Text.PT.RowSubtitle" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivRowIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_open_in_new"
        app:tint="?attr/ptTextMuted"
        android:importantForAccessibility="no" />

</LinearLayout>
