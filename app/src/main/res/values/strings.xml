    <string name="anki_content_flag_sentence">Sentence card marker (x)</string>
    <string name="anki_content_flag_sentence_desc">Emits \"x\" on sentence-mode sends only — use for template fields like Lapis\'s or JPMN\'s “IsSentenceCard”.</string>

    <string name="anki_content_flag_targeted_sentence">Targeted sentence card marker (x)</string>
    <string name="anki_content_flag_targeted_sentence_desc">Emits \"x\" on sentence sends that have a highlighted target word — use for JPMN\'s “IsTargetedSentenceCard”.</string>

    <string name="anki_content_flag_always_on">Always-on marker (x)</string>
    <string name="anki_content_flag_always_on_desc">Always emits \"x\". Use for template fields you want unconditionally enabled.</string>

