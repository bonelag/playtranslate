    <!-- ContentSource labels (dropdown options). Names persist in prefs,
         so re-labeling here is safe but renaming enum constants is not.
         The `*_desc` variants appear as the second-line subtitle in the
         source picker; they include a concrete example of what PT
         writes into the field. `<b>` markers are rendered via
         HtmlCompat so the example shows what the user will actually
         see on the card. -->
    <string name="anki_content_none">Empty</string>
    <string name="anki_content_none_desc">Sends nothing — the Anki field stays empty.</string>

    <string name="anki_content_expression">Word / headword</string>
    <string name="anki_content_expression_desc">The dictionary form of the highlighted word, no brackets. Example: 聞く</string>

    <string name="anki_content_expression_furigana">Word / headword with furigana</string>
    <string name="anki_content_expression_furigana_desc">The dictionary form with per-kanji furigana brackets, for fields rendered through \{\{furigana:\}\}. Example: 聞[き]く</string>

    <string name="anki_content_reading">Word reading (kana)</string>
    <string name="anki_content_reading_desc">The pure-kana reading of the highlighted word. Example: きく</string>

    <string name="anki_content_sentence">Source sentence</string>
    <string name="anki_content_sentence_desc">The source sentence with the highlighted word bolded. Example: 友達に<b>聞いた</b></string>

    <string name="anki_content_sentence_furigana">Source sentence with furigana</string>
    <string name="anki_content_sentence_furigana_desc">The source sentence with per-kanji furigana brackets, for fields rendered through \{\{furigana:\}\}. Example: 友達[ともだち]に<b>聞[き]いた</b></string>

    <string name="anki_content_sentence_translation">Translated sentence</string>
    <string name="anki_content_sentence_translation_desc">The translation of the source sentence in your selected target language.</string>

    <string name="anki_content_definition">Definition</string>
    <string name="anki_content_definition_desc">The dictionary definition(s) of the highlighted word, formatted as HTML.</string>

    <string name="anki_content_examples">Example sentences</string>
    <string name="anki_content_examples_desc">Tatoeba example sentences for the highlighted word, when available.</string>

    <string name="anki_content_picture">Screenshot</string>
    <string name="anki_content_picture_desc">A screenshot of the game screen, wrapped in &lt;img&gt; markup ready for a Picture / Screenshot field.</string>

    <string name="anki_content_frequency">Frequency stars</string>
    <string name="anki_content_frequency_desc">Frequency rating of the highlighted word as stars. Example: ★★★</string>

    <string name="anki_content_part_of_speech">Part of speech</string>
    <string name="anki_content_part_of_speech_desc">Part-of-speech tag for the highlighted word (word-mode cards only). Example: noun</string>

    <string name="anki_content_words_table">Words list (sentence cards)</string>
    <string name="anki_content_words_table_desc">A formatted list of every word PlayTranslate detected in the sentence, with readings and definitions.</string>

