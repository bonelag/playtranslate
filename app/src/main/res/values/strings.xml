    <!-- Permission / Onboarding -->
    <string name="onboarding_welcome_title">Welcome to PlayTranslate!</string>
    <string name="onboarding_welcome_tagline">Your companion app for playing games in other languages.</string>
    <string name="onboarding_welcome_body">Playing something you don\'t understand? Turn on-screen text into translations instantly.\n\nLearning a language? Word-by-word definitions, reading guides (furigana, pinyin), and one-tap Anki flashcards.</string>
    <string name="onboarding_welcome_row_placeholder">Tap to choose</string>
    <string name="onboarding_welcome_continue">Continue</string>
    <string name="onboarding_welcome_select_source">Select game language</string>
    <string name="onboarding_notif_title">Allow Notifications</string>
    <string name="onboarding_notif_body">Android requires apps that run in the background to display a status bar notification while active.\n\nThis will never send alerts, sounds, or banners — only a quiet persistent indicator that PlayTranslate is running.</string>
    <string name="onboarding_a11y_hint">Look for <b>PlayTranslate</b> under Downloaded apps.</string>
    <string name="onboarding_a11y_title">Enable Accessibility</string>
    <string name="onboarding_a11y_body"><b>PlayTranslate</b> uses Accessibility to:\n• Capture the game screen\n• Show translated text over your game\n• Look up words by dragging over game text\n• Display game screen controls\n\nIt does not read UI content, monitor input, or access personal data.</string>
    <string name="btn_grant_permission">Grant Permission</string>
    <string name="btn_open_a11y_settings">Open Accessibility Settings</string>
    <string name="btn_cant_enable_a11y">Can\'t enable?</string>
    <string name="restricted_settings_title">Allow Restricted Settings</string>
    <string name="restricted_settings_message">From PlayTranslate\'s Android settings page, select the button on the top right with three dots (⋮) and then select \"Allow restricted settings\". After authenticating, you should be able to turn on accessibility permissions.</string>
    <string name="btn_open_app_settings">Open PlayTranslate Settings</string>
    <string name="region_picker_no_preview">To see a preview of your selected region on the game screen, you must enable Accessibility Settings. This is also necessary to create new capture regions. Tap here to change.</string>
    <string name="custom_region_a11y_required_title">Accessibility required</string>
    <string name="custom_region_a11y_required_message">Adding custom regions requires the Accessibility permission. It\'s used to draw a live preview box on the game screen so you can see exactly what area you\'re selecting.\n\nGo to Settings → Accessibility → Installed apps → PlayTranslate → Enable.</string>

